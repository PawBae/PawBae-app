{
  "name": "pawbae-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --dir apps/desktop dev",
    "build": "pnpm --dir apps/desktop build",
    "tauri": "pnpm --dir apps/desktop tauri",
    "check": "pnpm --dir apps/desktop check",
    "test": "pnpm --dir apps/desktop test",
    "test:ci": "pnpm --dir apps/desktop test:ci",
    "pet-assets:check": "node scripts/validate-pet-assets.mjs",
    "bump": "node scripts/bump-version.mjs",
    "website:dev": "pnpm --dir apps/website dev",
    "website:build": "pnpm --dir apps/website build",
    "website:check": "pnpm --dir apps/website check",
    "lint": "biome check apps/desktop/src",
    "lint:fix": "biome check --write apps/desktop/src",
    "format": "biome format --write apps/desktop/src"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "undici": "^7.28.0"
    }
  }
}
