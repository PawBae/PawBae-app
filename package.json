{
  "name": "pawbae",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @pawbae/desktop dev",
    "build": "pnpm --filter @pawbae/desktop build",
    "preview": "pnpm --filter @pawbae/desktop preview",
    "check": "pnpm --filter @pawbae/desktop check",
    "lint": "biome check apps/desktop/src",
    "lint:fix": "biome check --write apps/desktop/src",
    "format": "biome format --write apps/desktop/src",
    "tauri": "pnpm --filter @pawbae/desktop tauri",
    "test": "pnpm --filter @pawbae/desktop test",
    "test:ci": "pnpm --filter @pawbae/desktop test:ci"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "undici": "^7.28.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
