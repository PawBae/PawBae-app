    "run-right": { "row": 1, "frames": 8, "fps": 12 },
    "dash":      { "row": 2, "frames": 8, "fps": 14, "flipX": true },
    "hold":      { "row": 3, "frames": 4, "fps": 4,  "loopRestMs": 1200 },
    "float":     { "row": 4, "frames": 5, "fps": 8,  "loopRestMs": 400 },
    "hide":      { "row": 5, "frames": 8, "fps": 8,  "loopRestMs": 1500 },
    "happy":     { "row": 6, "frames": 6, "fps": 6,  "loopRestMs": 800 },
    "pounce":    { "row": 7, "frames": 6, "fps": 12 },
    "blink":     { "row": 8, "frames": 6, "fps": 4,  "loopRestMs": 2000 },
    "thinking":  { "row": 8, "frames": 6, "fps": 4,  "loopRestMs": 1800 },

    "grab-wall":            { "row": 9,  "frames": 8, "fps": 12 },
    "grab-wall-flipped":    { "row": 9,  "frames": 8, "fps": 12, "flipX": true },
    "climb-wall":           { "row": 10, "frames": 8, "fps": 12 },
    "climb-wall-flipped":   { "row": 10, "frames": 8, "fps": 12, "flipX": true },
    "climb-ceiling":        { "row": 11, "frames": 8, "fps": 12 },
