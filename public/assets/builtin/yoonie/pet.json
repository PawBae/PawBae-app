    "falling":              { "row": 12, "frames": 2, "fps": 5,  "offsetCol": 0 },
    "jumping":              { "row": 12, "frames": 3, "fps": 9,  "offsetCol": 2 },
    "bouncing":             { "row": 12, "frames": 3, "fps": 10, "offsetCol": 5 },
    "reading":              { "row": 13, "frames": 8, "fps": 7,  "loopRestMs": 400 },
    "writing":              { "row": 14, "frames": 8, "fps": 9 },
    "running-shell":        { "row": 15, "frames": 8, "fps": 10 },
    "running-agent":        { "row": 16, "frames": 8, "fps": 8,  "loopRestMs": 250 },
    "asking-user":          { "row": 17, "frames": 8, "fps": 6,  "loopRestMs": 700 },
    "done-success":         { "row": 6,  "frames": 6, "fps": 8 },
    "done-fail":            { "row": 18, "frames": 8, "fps": 8 },
    "waiting":              { "row": 5, "frames": 8, "fps": 8, "loopRestMs": 1500 },
    "react-keyboard":       { "row": 14, "frames": 4, "fps": 14 },
    "react-mouse":          { "row": 7,  "frames": 5, "fps": 14 }
